# Camada de serviço dos mocks: true = mocks em memória (acervo, solicitações,
# sessões, admin). O auth NÃO depende desta flag.
VITE_USE_MOCK=true

# URL base do backend real. Quando definida, o login passa a usar a API real
# (POST /api/auth/login); os demais serviços continuam mock por enquanto.
# Defina em um .env.local (ignorado pelo git) para ativar localmente.
VITE_API_BASE_URL=http://localhost:3000
